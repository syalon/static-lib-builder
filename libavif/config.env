# =============================================================================
# 版本与构建集中配置 (Single source of truth)
# =============================================================================
# 想切换所有平台使用的 libavif / dav1d / OpenHarmony 版本，只需修改本文件。
# 所有 CI job 与本地构建脚本都会在开始时 `source config.env`。
# 请勿在此文件中使用引号包裹值，保持 KEY=VALUE 形式，便于 shell 直接 source。
# =============================================================================

# 产物基名 (统一命名约定)。最终包名: <PACKAGE_NAME>-<version>-<target>.<ext>
PACKAGE_NAME=libavif-dav1d

# libavif 源码 tag，见 https://github.com/AOMediaCodec/libavif/tags
LIBAVIF_VERSION=v1.3.0

# dav1d 源码 tag，见 https://code.videolan.org/videolan/dav1d/-/tags
DAV1D_VERSION=1.5.1

# OpenHarmony commandline-tools 版本 (用于 HarmonyOS 交叉编译)
# 镜像见 https://huggingface.co/csukuangfj/harmonyos-commandline-tools
OHOS_CLI_VERSION=5.0.5.200

# Android 最低 API level (NDK 交叉编译)
ANDROID_API=21

# Apple 平台最低部署版本
IOS_DEPLOYMENT_TARGET=13.0
MACOS_DEPLOYMENT_TARGET=11.0

# 是否内置 libyuv 以加速色彩转换。
# OFF: 关闭，保证 7 个平台都能稳定交叉编译 (默认)。
# ON : 打开，会额外交叉编译 libyuv 并静态链接进 libavif。
ENABLE_LIBYUV=ON

# 产物版本号后缀（用于命名打包文件），留空则使用 LIBAVIF_VERSION。
# 例如最终包名: libavif-dav1d-<PACKAGE_VERSION>-<platform>-<arch>.tar.gz
PACKAGE_VERSION=
