# =============================================================================
# FFmpeg minimal static 构建配置 (Single source of truth)
# =============================================================================
# 与内部引擎视频模块的 FFmpeg minimal 配置对齐（解码器 / 解封装器 /
# 解析器 / 协议 + 链接的 libav* 子库）。修改编解码器列表时请同步引擎侧文档。
# =============================================================================

PACKAGE_NAME=ffmpeg-minimal

# FFmpeg 源码分支（引擎侧绑定 7.1.x）
# https://github.com/FFmpeg/FFmpeg/branches
FFMPEG_VERSION=7.1

# 产物版本号后缀；留空则用 FFMPEG_VERSION
PACKAGE_VERSION=

# OpenHarmony commandline-tools（HarmonyOS 交叉编译）
OHOS_CLI_VERSION=5.0.5.200

ANDROID_API=21
IOS_DEPLOYMENT_TARGET=13.0
MACOS_DEPLOYMENT_TARGET=11.0

# 引擎视频模块链接的子库（不含 avdevice/avfilter/postproc）
FFMPEG_ENABLE_AVCODEC=1
FFMPEG_ENABLE_AVFORMAT=1
FFMPEG_ENABLE_SWSCALE=1
FFMPEG_ENABLE_SWRESAMPLE=1

# 许可：引擎默认 LGPL（不启 gpl / nonfree / version3）
FFMPEG_ENABLE_GPL=0
FFMPEG_ENABLE_VERSION3=0
FFMPEG_ENABLE_NONFREE=0

# minimal 编解码器列表（空格分隔，供脚本读取）
FFMPEG_DECODERS=vp9 h264 aac vorbis opus mp3 pcm_s16le pcm_f32le
FFMPEG_DEMUXERS=matroska mov mp3 wav ogg flac
FFMPEG_PARSERS=vp9 h264 aac opus vorbis mpegaudio
FFMPEG_PROTOCOLS=file
