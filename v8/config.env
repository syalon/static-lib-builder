# =============================================================================
# V8 版本与构建集中配置 (Single source of truth)
# =============================================================================
# 只改本文件即可切换 V8 版本与构建开关；CI 与本地脚本都会在开始时 `source config.env`。
# 请勿用引号包裹值，保持 KEY=VALUE，便于 shell 直接 source。
# workflow_dispatch 的输入可在运行时覆盖同名项。
# =============================================================================

# 产物基名 (统一命名约定)。最终包名: <PACKAGE_NAME>-<version>-<target>.<ext>
PACKAGE_NAME=v8

# 产物版本号 (用于打包命名)，留空则回退 V8_VERSION。
PACKAGE_VERSION=

# V8 源码版本 (对应 Chromium 里程碑的稳定 tag)。
# 版本对照见 https://chromiumdash.appspot.com/releases ，tag 列表见
# https://chromium.googlesource.com/v8/v8/+refs
# 嵌入者一般用某个稳定里程碑分支的 tag。
V8_VERSION=14.9.207.29

# --- 可调构建参数 (默认=推荐的"最小可嵌入"配置) ------------------------------

# 是否 Debug 构建。false=release (体积小、优化)。
IS_DEBUG=false

# 符号级别: 0=无符号(最小), 1=最少, 2=完整。
SYMBOL_LEVEL=0

# 是否启用 i18n / ICU 支持。false 可显著减小体积，但 Intl / RegExp unicode 部分不可用。关闭着简单的中文正则也能匹配。
V8_ENABLE_I18N=false

# 是否启用 WebAssembly。用不到可关掉以减小体积。
V8_ENABLE_WEBASSEMBLY=false

# 是否启用 Temporal API (新一代日期时间 API)。游戏脚本一般用 Date 即可，关掉可减小体积。
V8_ENABLE_TEMPORAL=false

# 是否启用主 JS 堆指针压缩 (对应宏 V8_COMPRESS_POINTERS)。
# 各平台独立配置，默认全部关闭；下游编译宏必须与对应平台产物一致。
# V8 14.9 在 Windows/clang-cl 无压缩构建中存在 MSVC/Torque 字段偏移不一致；Windows
# 构建脚本会应用 v8/patches/14.9.207.29-fix-msvc-no-pointer-compression.patch 修复。
#
# cppgc (Oilpan / C++ 堆) 有独立的一套压缩开关 cppgc_enable_pointer_compression：
#   在 64bit (arm64/x64/loong64/riscv64) 上 cppgc_enable_caged_heap 默认开，V8 的
#   BUILD.gn 会据此"强制" cppgc_enable_pointer_compression=true (无法在 args.gn 单独关)。
#   于是库会带宏 CPPGC_POINTER_COMPRESSION 编译，它决定公开头文件里 cppgc::Member /
#   v8::TracedReference 的布局。下游若不定义同样的宏 -> 布局错位 -> 初始化 cppgc 堆时
#   崩溃 (典型现象: Android 启动 Isolate 时崩)。
#
# 本仓库的处理: 由下面的 V8_ENABLE_CPPGC_CAGED_HEAP 控制 cppgc_enable_caged_heap。
#   （此项独立于下面的主堆压缩开关。）
V8_ENABLE_POINTER_COMPRESSION_MACOS=false
V8_ENABLE_POINTER_COMPRESSION_LINUX=false
V8_ENABLE_POINTER_COMPRESSION_ANDROID=false
V8_ENABLE_POINTER_COMPRESSION_WINDOWS=false

# 是否启用 cppgc (Oilpan / C++ 堆) 的 caged heap。
# false（默认，推荐嵌入场景）— 关掉 caged heap，连带关掉 young generation 与 cppgc 指针压缩，
#         令 CPPGC_CAGED_HEAP / CPPGC_YOUNG_GENERATION / CPPGC_POINTER_COMPRESSION 全部不定义，
#         与"下游不定义任何 cppgc 宏"的默认用法对齐，避免 cppgc::Member 布局错位导致的启动崩溃
#         (典型: Android 启动 Isolate 时崩)。
# true  — 恢复 V8 官方默认 (64bit 上开 caged heap，并被强制开启 cppgc 指针压缩)。此时库带宏
#         CPPGC_POINTER_COMPRESSION 编译，下游包含头文件时必须定义同样的宏，否则会崩。
V8_ENABLE_CPPGC_CAGED_HEAP=false

# Android 最低 API level (仅 android 目标使用)。
# 注意: V8/Chromium 要求 >= 23 (min_supported_sdk_version)，低于此值 gn gen 会断言失败。
ANDROID_API=24

# 是否将 V8 monolith 静态库链接进下游动态库 (.so / cdylib / dylib / DLL)。
# true  — 默认。GN 设置 v8_monolithic_for_shared_library=true，定义 V8_TLS_USED_IN_LIBRARY。
#         Linux 上 thread_local 从 local-exec (R_X86_64_TPOFF32, 无法 -shared) 改为 local-dynamic
#         并经由 getter 访问。Android 非 library 模式默认已是 local-dynamic，开启可保持行为一致。
# false — 仅适合 monolith 直接链入可执行文件 (binary)；Linux 链入 .so 会链接失败。
#
# 注意: 仅靠 extra_cflags 的 -ftls-model=global-dynamic 无效——V8 源码对 g_current_isolate_ 等
#       显式标注 __attribute__((tls_model(V8_TLS_MODEL)))，会覆盖编译器全局 flag。
#       须使用 V8 官方 GN 开关 v8_monolithic_for_shared_library (见 BUILD.gn)。
V8_MONOLITHIC_FOR_SHARED_LIBRARY=true

# --- 固定项 (脚本内写死，不建议改) --------------------------------------------
#   v8_monolithic=true            产出单一 libv8_monolith 静态库
#   is_component_build=false      静态库而非组件动态库
#   v8_use_external_startup_data=false  快照打进库，无需外部 .bin
#   use_custom_libcxx=false       用系统/工具链 libc++，便于下游链接
