# =============================================================================
# V8 版本与构建集中配置 (Single source of truth)
# =============================================================================
# 只改本文件即可切换 V8 版本与构建开关；CI 与本地脚本都会在开始时 `source config.env`。
# 请勿用引号包裹值，保持 KEY=VALUE，便于 shell 直接 source。
# workflow_dispatch 的输入可在运行时覆盖同名项。
# =============================================================================

# 产物基名 (统一命名约定)。最终包名: <PACKAGE_NAME>-<version>-<target>.<ext>
PACKAGE_NAME=v8

# 产物版本号 (用于打包命名)，留空则回退 V8_VERSION。
PACKAGE_VERSION=

# V8 源码版本 (对应 Chromium 里程碑的稳定 tag)。
# 版本对照见 https://chromiumdash.appspot.com/releases ，tag 列表见
# https://chromium.googlesource.com/v8/v8/+refs
# 嵌入者一般用某个稳定里程碑分支的 tag。
V8_VERSION=14.9.207.29

# --- 可调构建参数 (默认=推荐的"最小可嵌入"配置) ------------------------------

# 是否 Debug 构建。false=release (体积小、优化)。
IS_DEBUG=false

# 符号级别: 0=无符号(最小), 1=最少, 2=完整。
SYMBOL_LEVEL=0

# 是否启用 i18n / ICU 支持。false 可显著减小体积，但 Intl / RegExp unicode 部分不可用。关闭着简单的中文正则也能匹配。
V8_ENABLE_I18N=false

# 是否启用 WebAssembly。用不到可关掉以减小体积。
V8_ENABLE_WEBASSEMBLY=false

# 是否启用 Temporal API (新一代日期时间 API)。游戏脚本一般用 Date 即可，关掉可减小体积。
V8_ENABLE_TEMPORAL=false

# 是否启用指针压缩 (减小堆内存)。注意: 与下游必须一致；iOS 不支持(脚本会强制关闭)。
V8_ENABLE_POINTER_COMPRESSION=true

# Android 最低 API level (仅 android 目标使用)。
# 注意: V8/Chromium 要求 >= 23 (min_supported_sdk_version)，低于此值 gn gen 会断言失败。
ANDROID_API=24

# TLS 访问模型 (仅 Linux / Android 生效；macOS / Windows 无 ELF TLS 重定位问题)。
# V8 monolith 是静态库，下游会把它链接进最终产物；TLS 模型须与下游链接方式一致。
# 编译器通过 extra_cflags / extra_cxxflags 传入 -ftls-model=<值>。
#
# 可选值:
#   global-dynamic — 默认。可安全链接进 .so / cdylib；Android dlopen 唯一完全安全的选择。
#                    访问 TLS 略慢，对嵌入脚本引擎可忽略。
#   initial-exec   — 适合直接链接进可执行文件 (binary)，或启动时即加载的 .so。
#                    不适合 dlopen 动态加载 (Android 可能因 TLS surplus 不足而崩溃)。
#   local-exec     — 仅适合直接链接进可执行文件 (binary)。编译器默认值，TLS 访问最快；
#                    链接进 -shared 产物会失败 (如 x86_64 的 R_X86_64_TPOFF32)。
V8_TLS_MODEL=global-dynamic

# --- 固定项 (脚本内写死，不建议改) --------------------------------------------
#   v8_monolithic=true            产出单一 libv8_monolith 静态库
#   is_component_build=false      静态库而非组件动态库
#   v8_use_external_startup_data=false  快照打进库，无需外部 .bin
#   use_custom_libcxx=false       用系统/工具链 libc++，便于下游链接
